# ==================================================
# MedEquip Frontend Configuration (React + TypeScript + Vite)
# ==================================================
# Copy this file to .env and configure for your environment
# NEVER commit .env to version control!

# ==================================================
# APPLICATION
# ==================================================
VITE_APP_NAME=MedEquip
VITE_ENVIRONMENT=development

# ==================================================
# API CONFIGURATION
# ==================================================
# Backend API base URL (no trailing slash)
VITE_API_BASE_URL=http://localhost:8000/api/v1

# API request timeout in milliseconds
VITE_API_TIMEOUT=30000

# ==================================================
# FEATURES
# ==================================================
VITE_ENABLE_DEBUG=true
VITE_ENABLE_ANALYTICS=false

# ==================================================
# AUTHENTICATION
# ==================================================
# Local storage keys for JWT tokens
VITE_ACCESS_TOKEN_STORAGE_KEY=access_token
VITE_REFRESH_TOKEN_STORAGE_KEY=refresh_token

# JWT token expiration (in minutes, for client-side refresh logic)
VITE_ACCESS_TOKEN_EXPIRY_MINUTES=15
VITE_REFRESH_TOKEN_EXPIRY_DAYS=7

# ==================================================
# UI CONFIGURATION
# ==================================================
# Pagination
VITE_DEFAULT_PAGE_SIZE=20

# Timeouts
VITE_CART_CHECKOUT_TIMEOUT_SECONDS=300
VITE_PRODUCT_SEARCH_DEBOUNCE_MS=300

# ==================================================
# MONITORING
# ==================================================
VITE_ENABLE_PERFORMANCE_MONITORING=false
VITE_ENABLE_ERROR_REPORTING=false

# Analytics service (if enabled)
VITE_ANALYTICS_KEY=
VITE_ANALYTICS_DOMAIN=

# ==================================================
# EXTERNAL SERVICES (Optional)
# ==================================================
# Payment gateway (if used)
VITE_PAYMENT_GATEWAY_KEY=

# Map service (if used)
VITE_MAP_API_KEY=
