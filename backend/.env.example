# ==================================================
# MedEquip Backend Configuration
# ==================================================
# Copy this file to .env and configure for your environment
# NEVER commit .env to version control!

# ==================================================
# GENERAL
# ==================================================
SECRET_KEY=your-super-secret-key-change-in-production
DEBUG=False
ENVIRONMENT=development
TIME_ZONE=UTC
LANGUAGE_CODE=en-us
USE_I18N=True
USE_TZ=True

# ==================================================
# APPLICATION
# ==================================================
APP_NAME=MedEquip
APP_VERSION=1.0.0
API_VERSION=v1

# ==================================================
# HOSTS & ORIGINS
# ==================================================
ALLOWED_HOSTS=localhost,127.0.0.1,api.medequip.local
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:5173

# ==================================================
# DATABASE
# ==================================================
# Option 1: Using DATABASE_URL
# DATABASE_URL=postgresql://user:password@localhost:5432/medequip

# Option 2: Using DB_* or POSTGRES_* components
DB_NAME=medequip
DB_USER=medequip
DB_PASSWORD=medequip
DB_HOST=localhost
DB_PORT=5432

# PostgreSQL aliases (optional; used when DB_* is unset)
# POSTGRES_DB=medequip
# POSTGRES_USER=medequip
# POSTGRES_PASSWORD=medequip
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432

DB_CONN_MAX_AGE=600
DB_CONNECT_TIMEOUT=10
DB_SSL_MODE=prefer

# ==================================================
# REDIS
# ==================================================
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_DB=0
REDIS_SESSION_DB=1
REDIS_KPI_DB=2
REDIS_LOCK_DB=3
REDIS_SOCKET_CONNECT_TIMEOUT=5
REDIS_SOCKET_TIMEOUT=5
CACHE_KEY_PREFIX=medequip

# ==================================================
# CELERY
# ==================================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=django-db
CELERY_ACCEPT_CONTENT=json
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_TIMEZONE=UTC
CELERY_TASK_TRACK_STARTED=True
CELERY_TASK_ACKS_LATE=True
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_TASK_TIME_LIMIT=600
CELERY_TASK_MAX_RETRIES=5
CELERY_BEAT_SCHEDULER=django_celery_beat.schedulers:DatabaseScheduler
CELERY_TASK_ALWAYS_EAGER=False
CELERY_TASK_EAGER_PROPAGATES=True

# ==================================================
# JWT AUTHENTICATION
# ==================================================
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7
JWT_ROTATE_REFRESH_TOKENS=True
JWT_BLACKLIST_AFTER_ROTATION=True
JWT_UPDATE_LAST_LOGIN=True
JWT_ALGORITHM=HS256
JWT_AUTH_HEADER_TYPES=Bearer
JWT_AUTH_HEADER_NAME=HTTP_AUTHORIZATION
JWT_USER_ID_FIELD=id
JWT_USER_ID_CLAIM=user_id
JWT_TOKEN_OBTAIN_SERIALIZER=apps.accounts.serializers.CustomTokenObtainPairSerializer

# ==================================================
# EMAIL
# ==================================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@medequip.com
SERVER_EMAIL=server@medequip.com

# ==================================================
# FILE STORAGE
# ==================================================
USE_S3=False
MEDIA_URL=/media/
MEDIA_ROOT=media

AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_STORAGE_BUCKET_NAME=medequip-bucket
AWS_S3_REGION_NAME=us-east-1
AWS_S3_CUSTOM_DOMAIN=
AWS_S3_CACHE_CONTROL=max-age=86400
AWS_LOCATION=media
AWS_MEDIA_URL=https://medequip-bucket.s3.amazonaws.com/media/
DEFAULT_FILE_STORAGE=storages.backends.s3boto3.S3Boto3Storage

# ==================================================
# STATIC FILES
# ==================================================
STATIC_URL=/static/
STATIC_ROOT=staticfiles
STATICFILES_STORAGE=whitenoise.storage.CompressedManifestStaticFilesStorage

# ==================================================
# CORS
# ==================================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_ALL_ORIGINS=False

# ==================================================
# FRONTEND INTEGRATION
# ==================================================
FRONTEND_URL=http://localhost:3000
FRONTEND_ADMIN_URL=http://localhost:3000/admin
PUBLIC_API_URL=http://localhost:8000/api/v1

# ==================================================
# API
# ==================================================
API_PAGE_SIZE=20
API_DOCS_TITLE=MedEquip API
API_DOCS_DESCRIPTION=Hospital Equipment Sales Platform API
API_DOCS_SERVE_INCLUDE_SCHEMA=False
API_DOCS_COMPONENT_SPLIT_REQUEST=True

# ==================================================
# RATE LIMITING
# ==================================================
THROTTLE_USER_RATE=1000/hour
THROTTLE_ANON_RATE=100/hour

# ==================================================
# SECURITY
# ==================================================
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
X_FRAME_OPTIONS=DENY
SECURE_BROWSER_XSS_FILTER=True
SECURE_CONTENT_TYPE_NOSNIFF=True

# Production guard: comma-separated placeholder keys that must not be used
INSECURE_SECRET_KEYS=your-super-secret-key-change-in-production,dev-insecure-key-change-in-prod

# ==================================================
# LOGGING
# ==================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_JSON_FORMAT=%(asctime)s %(name)s %(levelname)s %(message)s request_id=%(request_id)s
LOG_VERBOSE_FORMAT={levelname} {asctime} {module} {process:d} {thread:d} {message}
LOG_DJANGO_LEVEL=WARNING

# ==================================================
# MONITORING
# ==================================================
ENABLE_METRICS=True
ENABLE_HEALTHCHECKS=True
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_SEND_DEFAULT_PII=False

# ==================================================
# AXES (Brute-force Protection)
# ==================================================
AXES_ENABLED=False
AXES_FAILURE_LIMIT=5
AXES_COOLOFF_MINUTES=15
AXES_LOCKOUT_CALLABLE=apps.accounts.utils.axes_lockout_response
AXES_RESET_ON_SUCCESS=True
AXES_ENABLE_ACCESS_FAILURE_LOG=True

# ==================================================
# DEVELOPMENT
# ==================================================
INTERNAL_IPS=127.0.0.1,localhost

# ==================================================
# DOMAIN: KPI
# ==================================================
KPI_CACHE_TTL=300
KPI_REALTIME_ENABLED=True
KPI_SNAPSHOT_CACHE_TTL=300
PRODUCT_CACHE_TTL=600
SEARCH_CACHE_TTL=300

# ==================================================
# DOMAIN: CART
# ==================================================
CART_TTL_DAYS=30
CART_MAX_ITEMS=100

# ==================================================
# DOMAIN: ORDERS
# ==================================================
ORDER_NUMBER_PREFIX=ORD
ORDER_CANCELLATION_WINDOW_MINUTES=60

# ==================================================
# DOMAIN: INVENTORY
# ==================================================
LOW_STOCK_THRESHOLD=5
LOCK_TIMEOUT_SECONDS=30
INVENTORY_RECONCILIATION_INTERVAL=3600

# ==================================================
# DOMAIN: NOTIFICATIONS
# ==================================================
EMAIL_RETRY_LIMIT=5
EMAIL_RETRY_DELAY_SECONDS=60
NOTIFICATION_QUEUE_SIZE=1000

# ==================================================
# AUTHENTICATION
# ==================================================
AUTH_PASSWORD_MIN_LENGTH=8
AUTH_SESSION_TIMEOUT_MINUTES=1440
